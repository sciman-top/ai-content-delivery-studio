<Window x:Class="ImageSeriesStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F6F7F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="112" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#20242B" Padding="16,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LanguageLabel}"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              MinWidth="112"
                              Height="28"
                              Margin="0,0,16,0" />
                    <TextBlock Text="{Binding ProviderMode}"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding AppTitle}"
                           Foreground="#FFFFFF"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="0,0,1,0">
            <DockPanel Margin="14">
                <TextBlock DockPanel.Dock="Top" Text="{Binding WorkspaceHeader}" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedIndex="1"
                         BorderThickness="0"
                         Background="Transparent" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Grid.Column="1" Margin="12" ItemsSource="{Binding WorkbenchTabs}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding EmptyState}"
                                   Foreground="#5E6978"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlan}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPrompts}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsQueue}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlan}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#E9EDF3" BorderBrush="#D4DAE5" BorderThickness="1">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="2.1*" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DataContext.PlanSeriesColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DataContext.PlanItemColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DataContext.PlanBriefColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DataContext.PlanStatusColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding DataContext.NoPlanRowsText, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                       Foreground="#5E6978"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPlan}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.HasPlanRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="2" BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.HasPlanRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataContext.PlanRows, RelativeSource={RelativeSource AncestorType=TabControl}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="2.1*" />
                                                            <ColumnDefinition Width="110" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding SeriesTitle}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ItemTitle}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Brief}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding StatusText}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPrompts}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#E9EDF3" BorderBrush="#D4DAE5" BorderThickness="1">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="2.4*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DataContext.PromptVersionColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DataContext.PromptItemColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DataContext.PromptTextColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DataContext.PromptSettingsColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DataContext.PromptCreatedColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding DataContext.NoPromptRowsText, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                       Foreground="#5E6978"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPrompts}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.HasPromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="2" BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.HasPromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataContext.PromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="2.4*" />
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="130" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Version}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ItemTitle}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding PromptText}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding SettingsSummary}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding CreatedAt}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsQueue}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#E9EDF3" BorderBrush="#D4DAE5" BorderThickness="1">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DataContext.QueueItemColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DataContext.QueueStatusColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DataContext.QueueAttemptsColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DataContext.QueueOutputColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DataContext.QueueErrorColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="10,0,0,0" />
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding DataContext.NoQueueRowsText, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                       Foreground="#5E6978"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsQueue}" Value="True" />
                                                    <Condition Binding="{Binding DataContext.HasQueueRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="2" BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.HasQueueRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataContext.QueueRows, RelativeSource={RelativeSource AncestorType=TabControl}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="1.4*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding ItemTitle}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Status}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Attempts}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding OutputPath}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="#4B5563"
                                                                   Margin="10,0,0,0" />
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding ErrorMessage}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#8A3B3B"
                                                                   Margin="10,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <Border Grid.Row="1" Grid.Column="2" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <TextBlock Text="{Binding InspectorTitle}" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="{Binding InspectorSummary}" TextWrapping="Wrap" Foreground="#4B5563" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="{Binding ProjectNameLabel}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding CreateProjectText}"
                        Command="{Binding CreateProjectCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,18" />

                <TextBlock Text="{Binding CurrentProjectTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="{Binding CurrentProjectSummary}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,14" />

                <TextBlock Text="{Binding FakePlanningTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="{Binding PlanningGoalLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningGoal, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningAudienceLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningAudience, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningItemCountLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningItemCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningStyleBriefLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningStyleBrief, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding RunFakePlanningText}"
                        Command="{Binding RunFakePlanningCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14" />

                <TextBlock Text="{Binding AvailableProjectsTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         MinHeight="120" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="{Binding PlanEditorTitle}" FontWeight="SemiBold" Margin="0,0,0,10" />
                <TextBlock Text="{Binding SeriesTitleLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewSeriesTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding SeriesDescriptionLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewSeriesDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding CreateSeriesText}"
                        Command="{Binding CreateSeriesCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12" />

                <TextBlock Text="{Binding AvailableSeriesTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding Series}"
                         SelectedItem="{Binding SelectedSeries, Mode=TwoWay}"
                         DisplayMemberPath="Title"
                         MinHeight="82"
                         Margin="0,0,0,12" />

                <TextBlock Text="{Binding ItemTitleLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewItemTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding ItemBriefLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewItemBrief, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding AddItemText}"
                        Command="{Binding AddItemCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12" />

                <TextBlock Text="{Binding SeriesItemsTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding SeriesItems}"
                         SelectedItem="{Binding SelectedSeriesItem, Mode=TwoWay}"
                         DisplayMemberPath="Title"
                         MinHeight="82"
                         Margin="0,0,0,14" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="{Binding PromptEditorTitle}" FontWeight="SemiBold" Margin="0,0,0,10" />
                <TextBlock Text="{Binding SelectedItemTitle}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding SelectedSeriesItemTitleText}"
                           TextWrapping="Wrap"
                           Foreground="#4B5563"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding PromptTextLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPromptText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="88"
                         Margin="0,0,0,6" />
                <TextBlock Text="{Binding DefaultGenerationSettingsText}" Foreground="#5E6978" Margin="0,0,0,8" />
                <Button Content="{Binding CreatePromptVersionText}"
                        Command="{Binding CreatePromptVersionCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12" />

                <TextBlock Text="{Binding PromptHistoryTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding PromptVersions}"
                         DisplayMemberPath="VersionNumber"
                         MinHeight="82"
                         Margin="0,0,0,12" />

                <Button Content="{Binding RunFakeGenerationText}"
                        Command="{Binding RunFakeGenerationCommand}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,12">
                <TextBlock DockPanel.Dock="Top" Text="{Binding ActivityTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ActivityItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#4B5563" Margin="0,0,0,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
