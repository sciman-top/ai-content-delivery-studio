<Window x:Class="ImageSeriesStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:ImageSeriesStudio.App.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F6F7F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="112" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#20242B" Padding="16,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LanguageLabel}"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              MinWidth="112"
                              Height="28"
                              Margin="0,0,16,0" />
                    <TextBlock Text="{Binding ProviderMode}"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding AppTitle}"
                           Foreground="#FFFFFF"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="0,0,1,0">
            <DockPanel Margin="14">
                <TextBlock DockPanel.Dock="Top" Text="{Binding WorkspaceHeader}" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedIndex="1"
                         BorderThickness="0"
                         Background="Transparent" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Grid.Column="1" Margin="12" ItemsSource="{Binding WorkbenchTabs}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding EmptyState}"
                                   Foreground="#5E6978"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBrief}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPlan}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPrompts}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsQueue}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsGallery}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsReview}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDelivery}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsGraph}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <views:BriefWorkflowView Grid.Row="1" Margin="0,16,0,0" />
                        <views:PlanView Grid.Row="1" Margin="0,16,0,0" />
                        <views:PromptsView Grid.Row="1" Margin="0,16,0,0" />
                        <views:QueueView Grid.Row="1" Margin="0,16,0,0" />
                        <views:GalleryView Grid.Row="1" Margin="0,16,0,0" />
                        <views:ReviewView Grid.Row="1" Margin="0,16,0,0" />
                        <views:DeliveryView Grid.Row="1" Margin="0,16,0,0" />
                        <views:WorkflowGraphView Grid.Row="1" Margin="0,16,0,0" />
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <Border Grid.Row="1" Grid.Column="2" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <TextBlock Text="{Binding InspectorTitle}" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="{Binding InspectorSummary}" TextWrapping="Wrap" Foreground="#4B5563" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="Provider Center" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="{Binding ProviderCenter.SummaryText}"
                           TextWrapping="Wrap"
                           Foreground="#4B5563"
                           Margin="0,0,0,8" />
                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Button Content="Refresh"
                            Command="{Binding RefreshProviderCenterCommand}"
                            Margin="0,0,4,0" />
                    <Button Content="Test"
                            Command="{Binding CheckProviderHealthCommand}"
                            Margin="4,0,0,0" />
                </UniformGrid>
                <ItemsControl ItemsSource="{Binding ProviderCenter.ProviderRows}" Margin="0,0,0,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#D9DEE8"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Model}"
                                               Foreground="#4B5563"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding SecretSummary}"
                                               Foreground="#4B5563"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding ConcurrencySummary}"
                                               Foreground="#4B5563"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding HealthSummary}"
                                               Foreground="#4B5563"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,12,0,14" />

                <TextBlock Text="{Binding ProjectNameLabel}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding CreateProjectText}"
                        Command="{Binding CreateProjectCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,18" />

                <TextBlock Text="{Binding CurrentProjectTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="{Binding CurrentProjectSummary}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,14" />

                <TextBlock Text="{Binding StyleRecipeInspectorTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ImageTypePresetLabel}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding ImageTypePresetOptions}"
                          SelectedItem="{Binding SelectedImageTypePresetOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          MinHeight="28"
                          Margin="0,0,0,6" />
                <TextBlock Text="{Binding StyleGuideLabel}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding StyleGuideOptions}"
                          SelectedItem="{Binding SelectedStyleGuideOption, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          MinHeight="28"
                          Margin="0,0,0,6" />
                <TextBlock Text="{Binding GenerationRecipeLabel}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding GenerationRecipeOptions}"
                          SelectedItem="{Binding SelectedGenerationRecipeOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          MinHeight="28"
                          Margin="0,0,0,6" />
                <TextBlock Text="{Binding StyleRecipeSummaryTitle}" FontWeight="SemiBold" Margin="0,4,0,4" />
                <TextBlock Text="{Binding StyleRecipeSummaryText}"
                           TextWrapping="Wrap"
                           Foreground="#4B5563"
                           Margin="0,0,0,14" />

                <TextBlock Text="{Binding FakePlanningTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="{Binding PlanningGoalLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningGoal, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningAudienceLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningAudience, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningItemCountLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningItemCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding PlanningStyleBriefLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewPlanningStyleBrief, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="{Binding RunFakePlanningText}"
                        Command="{Binding RunFakePlanningCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="{Binding DocumentIllustrationTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="{Binding DocumentSourceTextLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewDocumentSourceText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="88"
                         Margin="0,0,0,6" />
                <TextBlock Text="{Binding DocumentAudienceLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewDocumentAudience, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                <TextBlock Text="{Binding DocumentStrictnessLabel}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding DocumentStrictnessOptions}"
                          SelectedItem="{Binding SelectedDocumentStrictnessOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          MinHeight="28"
                          Margin="0,0,0,8" />
                <Button Content="{Binding RunFakeDocumentPlanningText}"
                        Command="{Binding RunFakeDocumentPlanningCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8" />
                <TextBlock Text="{Binding DocumentPlanningResultText}" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="{Binding DocumentPlanningResultSummary}"
                           TextWrapping="Wrap"
                           Foreground="#4B5563"
                           Margin="0,0,0,14" />

                <TextBlock Text="{Binding AvailableProjectsTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         MinHeight="120" />

                <Separator Margin="0,18,0,14" />

                <views:PlanEditorPanelView Margin="0,0,0,14" />

                <Separator Margin="0,18,0,14" />

                <views:PromptEditorPanelView Margin="0,0,0,12" />

                <Separator Margin="0,10,0,14" />

                <views:ImageEditPanelView Margin="0,0,0,12" />

                <views:ReviewApprovalPanelView />
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#FFFFFF" BorderBrush="#D9DEE8" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,12">
                <TextBlock DockPanel.Dock="Top" Text="{Binding ActivityTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ActivityItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#4B5563" Margin="0,0,0,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
