<UserControl x:Class="ImageSeriesStudio.App.Views.ReviewApprovalPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Button Content="{Binding RunFakeReviewText}"
                Command="{Binding RunFakeReviewCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,8" />
        <TextBlock Text="{Binding FinalApprovalReviewerLabel}" Margin="0,0,0,4" />
        <TextBox Text="{Binding FinalApprovalReviewer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
        <TextBlock Text="{Binding FinalApprovalNotesLabel}" Margin="0,0,0,4" />
        <TextBox Text="{Binding FinalApprovalNotes, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="64"
                 Margin="0,0,0,8" />
        <Button Content="{Binding ApproveSelectedReviewText}"
                Command="{Binding ApproveSelectedReviewCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,6" />
        <Button Content="{Binding RejectSelectedReviewText}"
                Command="{Binding RejectSelectedReviewCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,8" />
        <Button Content="{Binding ExportDeliveryText}"
                Command="{Binding ExportDeliveryCommand}"
                HorizontalAlignment="Stretch" />
    </StackPanel>
</UserControl>
