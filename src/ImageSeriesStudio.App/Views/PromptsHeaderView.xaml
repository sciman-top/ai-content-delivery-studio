<UserControl x:Class="ImageSeriesStudio.App.Views.PromptsHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Background="#E9EDF3" BorderBrush="#D4DAE5" BorderThickness="1">
        <Grid Margin="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="2.4*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding DataContext.PromptVersionColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="{Binding DataContext.PromptItemColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0" />
            <TextBlock Grid.Column="2"
                       Text="{Binding DataContext.PromptTextColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0" />
            <TextBlock Grid.Column="3"
                       Text="{Binding DataContext.PromptSettingsColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0" />
            <TextBlock Grid.Column="4"
                       Text="{Binding DataContext.PromptCreatedColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0" />
        </Grid>
    </Border>
</UserControl>
