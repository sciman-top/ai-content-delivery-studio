<UserControl x:Class="ImageSeriesStudio.App.Views.PromptsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPrompts}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E9EDF3" BorderBrush="#D4DAE5" BorderThickness="1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding DataContext.PromptVersionColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DataContext.PromptItemColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
                <TextBlock Grid.Column="2"
                           Text="{Binding DataContext.PromptTextColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
                <TextBlock Grid.Column="3"
                           Text="{Binding DataContext.PromptSettingsColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
                <TextBlock Grid.Column="4"
                           Text="{Binding DataContext.PromptCreatedColumn, RelativeSource={RelativeSource AncestorType=TabControl}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="{Binding DataContext.NoPromptRowsText, RelativeSource={RelativeSource AncestorType=TabControl}}"
                   Foreground="#5E6978"
                   Margin="0,14,0,0"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPrompts}" Value="True" />
                                <Condition Binding="{Binding DataContext.HasPromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Border Grid.Row="2" BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HasPromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DataContext.PromptRows, RelativeSource={RelativeSource AncestorType=TabControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="2.4*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Version}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ItemTitle}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PromptText}"
                                               TextWrapping="Wrap"
                                               Foreground="#4B5563"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SettingsSummary}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#4B5563"
                                               Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding CreatedAt}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#4B5563"
                                               Margin="10,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
