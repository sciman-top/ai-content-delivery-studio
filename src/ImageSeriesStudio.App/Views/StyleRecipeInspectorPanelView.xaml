<UserControl x:Class="ImageSeriesStudio.App.Views.StyleRecipeInspectorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="{Binding StyleRecipeInspectorTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Text="{Binding ImageTypePresetLabel}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding ImageTypePresetOptions}"
                  SelectedItem="{Binding SelectedImageTypePresetOption, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"
                  MinHeight="28"
                  Margin="0,0,0,6" />
        <TextBlock Text="{Binding StyleGuideLabel}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding StyleGuideOptions}"
                  SelectedItem="{Binding SelectedStyleGuideOption, Mode=TwoWay}"
                  DisplayMemberPath="Name"
                  MinHeight="28"
                  Margin="0,0,0,6" />
        <TextBlock Text="{Binding GenerationRecipeLabel}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding GenerationRecipeOptions}"
                  SelectedItem="{Binding SelectedGenerationRecipeOption, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"
                  MinHeight="28"
                  Margin="0,0,0,6" />
        <TextBlock Text="{Binding StyleRecipeSummaryTitle}" FontWeight="SemiBold" Margin="0,4,0,4" />
        <TextBlock Text="{Binding StyleRecipeSummaryText}"
                   TextWrapping="Wrap"
                   Foreground="#4B5563"
                   Margin="0,0,0,14" />
    </StackPanel>
</UserControl>
