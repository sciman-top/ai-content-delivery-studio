<UserControl x:Class="ContentDeliveryStudio.App.Views.WorkflowGraphRowsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.HasWorkflowGraphRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DataContext.WorkflowGraphRows, RelativeSource={RelativeSource AncestorType=TabControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding NodeType}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#4B5563"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Summary}"
                                           TextWrapping="Wrap"
                                           Foreground="#4B5563"
                                           Margin="10,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding LinksTo}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#4B5563"
                                           Margin="10,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Border>
</UserControl>
