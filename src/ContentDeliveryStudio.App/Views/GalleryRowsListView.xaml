<UserControl x:Class="ContentDeliveryStudio.App.Views.GalleryRowsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:services="clr-namespace:ContentDeliveryStudio.App.Services"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <services:GalleryThumbnailPathConverter x:Key="GalleryThumbnailPathConverter" />
    </UserControl.Resources>
    <Border BorderBrush="#D4DAE5" BorderThickness="1,0,1,1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.HasGalleryRows, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <ListBox ItemsSource="{Binding DataContext.GalleryRows, RelativeSource={RelativeSource AncestorType=TabControl}}"
                 SelectedItem="{Binding DataContext.SelectedGalleryRow, RelativeSource={RelativeSource AncestorType=TabControl}, Mode=TwoWay}"
                 BorderThickness="0"
                 Background="Transparent"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E3E7EF" BorderThickness="0,0,0,1" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="2.3*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ItemTitle}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1"
                                    Width="112"
                                    Height="84"
                                    BorderBrush="#D4DAE5"
                                    BorderThickness="1"
                                    Background="#F6F7F9"
                                    Margin="10,0,0,0">
                                <Image Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor">
                                    <Image.Source>
                                        <Binding Path="AssetPath"
                                                 Converter="{StaticResource GalleryThumbnailPathConverter}"
                                                 IsAsync="True" />
                                    </Image.Source>
                                </Image>
                            </Border>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="{Binding AssetPath}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#4B5563" />
                                <TextBlock Text="{Binding MetadataPath}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#5E6978"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Border>
</UserControl>
